# .env.example — copy to .env.local for *local* provisioning/seeding or a manual `pnpm deploy`:
#   set -a; source .env.local; set +a
#
# IMPORTANT: the CI pipeline does NOT read this file. .github/workflows/deploy.yml pulls these from
# GitHub Environment secrets/variables instead (see docs/deploy.md). If you deploy via CI you do not
# need the credentials below on your machine at all — prefer `wrangler login` for one-off local
# provisioning/seeding.

# --- Deploy credentials (CI: GitHub secrets; local: only for a manual `pnpm deploy`) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Target names (deploy render). Leave empty to use the committed production names. ---
# Set these (typically in a GitHub Environment) to deploy a non-prod target like staging.
SIGMA_WEB_NAME=          # e.g. sigma-stage
SIGMA_ETL_NAME=          # e.g. sigma-etl-stage
SIGMA_WORKFLOW_NAME=     # e.g. sigma-refresh-stage

# --- D1 name: used by BOTH the bootstrap/import/seed scripts AND the deploy render ---
# Defaults to `sigma` when unset. Set to e.g. `sigma-stage` to provision/seed/deploy staging.
SIGMA_D1_NAME=

# D1 database_id printed by `bootstrap.mjs --apply`. The committed wrangler.* keep a zero-UUID dummy
# for local dev; the deploy render substitutes the real id. Per environment.
SIGMA_D1_ID=

